# Example environment file for IBM watsonx.ai Granite integration.
IBM_API_KEY=replace-with-your-ibm-cloud-api-key
IBM_PROJECT_ID=replace-with-your-watsonx-project-id
IBM_REGION=us-south
IBM_GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: set true only when you intentionally want local demo output.
DEMO_MODE=false
